# =====================================================
# Backup files generated by the optimizer (don't commit user data)
# =====================================================
NIC-Backup/
*.bak

# =====================================================
# OS / IDE
# =====================================================
Thumbs.db
.DS_Store
desktop.ini
*.swp
*~
.vs/
.vscode/
.idea/

# =====================================================
# Temp / debug / conflict files
# =====================================================
*.tmp
*.log
*.cache
*.broken

# =====================================================
# Safety net - private files patterns
# (osobiste skrypty trzymaj w ../PRYWATNE/ poza repo)
# =====================================================
PRYWATNE/
private/
*.private.*
*-personal.*
secrets.*
.env
.env.local

# =====================================================
# Binary / archive / installer files
# =====================================================
*.zip
*.7z
*.rar
*.exe
*.dll
*.msi

# =====================================================
# PowerShell
# =====================================================
PowerShell_transcript.*
*.psproj.user
